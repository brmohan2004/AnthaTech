# ============================================
# ADMIN PANEL — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_PASSWORD=your-database-password

# --- Storage (supabase or r2) ---
VITE_STORAGE_PROVIDER=supabase

# --- Supabase Edge Functions ---
VITE_EDGE_FN_URL=https://your-project-id.supabase.co/functions/v1

# --- Email Service (Brevo) ---
BREVO_API_KEY=xkeysib-your-api-key

# --- Cloudflare R2 (uncomment when ready) ---
# CF_ACCOUNT_ID=your-cf-account-id
# CF_ACCESS_KEY_ID=your-r2-access-key-id
# CF_API_TOKEN=your-cf-api-token
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=anthatech-media
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
